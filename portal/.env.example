# Oakrange Certificate Portal — environment variables
# Copy to `.env.local` for local development. Never commit real secrets.

# Supabase project URL (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://dptzwrrydxicehgjnbxf.supabase.co

# Optional: same URL for server-only scripts (e.g. tests/rls-phase2.mjs). Falls back to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://dptzwrrydxicehgjnbxf.supabase.co

# Supabase anon (public) key — safe to expose to the browser; RLS applies
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only. Used in later phases for signed URLs after
# access checks. Never expose to the client or prefix with NEXT_PUBLIC_.
# Also used by tests/rls-phase2.mjs against a dev project (with migrations applied).
SUPABASE_SERVICE_ROLE_KEY=
