# Oakrange Certificate Portal — environment variables
# Copy to `.env.local` for local development. Never commit real secrets.

# Supabase project URL (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Optional: same URL for server-only scripts (e.g. tests/rls-phase2.mjs).
# Falls back to NEXT_PUBLIC_SUPABASE_URL when unset.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose to the browser; RLS applies
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only. Used for signed URLs after access checks and
# admin user provisioning. Never expose to the client or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: base URL for automated runtime tests (default http://127.0.0.1:3000)
# PHASE6_BASE_URL=http://127.0.0.1:3000
# PHASE7_BASE_URL=http://127.0.0.1:3000

# Set to 1 in CI to fail RLS tests when env is missing (default: skip)
# REQUIRE_RLS_TESTS=1
